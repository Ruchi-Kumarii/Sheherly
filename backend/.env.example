# ============================================================
#  SHEHERLY — Environment Variables
#  1. Copy this file:  cp .env.example .env
#  2. Fill in your own values below
#  3. Never commit .env to version control
# ============================================================


# ── Server Ports ─────────────────────────────────────────────
# Port for the admin/data Node.js API
ADMIN_PORT=9000

# Port for the map/routing Node.js API
MAP_PORT=8002


# ── Gmail (signup email delivery) ────────────────────────────
# The Gmail address that sends generated passwords to new users
GMAIL_USER=your_gmail@gmail.com

# App Password — NOT your regular Gmail password
# How to generate:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification if not already on
#   3. Go to App Passwords → Select app: Mail → Generate
#   4. Paste the 16-character password below (no spaces)
GMAIL_APP_PASSWORD=your_16_char_app_password


# # ── Gmail (signup email delivery) ─────────────────
# GMAIL_USER=sheherly2@gmail.com
# GMAIL_APP_PASSWORD=jvsxpcisriacuvqh


# ── OpenRouteService (map routing) ───────────────────────────
# Free API key for driving / walking / cycling route calculation
# Sign up at: https://openrouteservice.org/dev/#/signup
# Then go to Dashboard → Request a Token
ORS_API_KEY=your_ors_api_key


# ── OpenRouter (AI chatbot) ───────────────────────────────────
# API key for GPT-3.5-turbo access via OpenRouter
# Sign up at: https://openrouter.ai
# Then go to: https://openrouter.ai/keys → Create Key
OPENROUTER_API_KEY=your_openrouter_api_key
